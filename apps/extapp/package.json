{
  "name": "extapp",
  "description": "manifest.json description",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "test": "tsc --noEmit",
    "submit": "wxt submit --chrome-zip .output/*-chrome.zip",
    "validate:store": "tsx scripts/validate-store-assets.ts",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@repo/ui": "*",
    "@tailwindcss/vite": "^4.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@googleapis/chromewebstore": "^3.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wxt": "^0.20.27"
  }
}
